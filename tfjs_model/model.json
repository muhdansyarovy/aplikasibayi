import json
with open('model.json') as f:
    m = json.load(f)
# Fix 1: batch_shape -> batch_input_shape
for l in m['modelTopology']['model_config']['config']['layers']:
    if l['class_name'] == 'InputLayer' and 'batch_shape' in l['config']:
        l['config']['batch_input_shape'] = l['config'].pop('batch_shape')
# Fix 2: Strip sequential/ prefix
for mf in m['weightsManifest']:
    for w in mf['weights']:
        if w['name'].startswith('sequential/'):
            w['name'] = w['name'][len('sequential/'):]
with open('model.json', 'w') as f:
    json.dump(m, f)
